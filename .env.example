# ---- Scraper runtime ----
PORT=8092
NODE_ENV=development
LOG_LEVEL=info

# ---- Storage paths (relative to scraper root) ----
STORAGE_DIR=./storage
RUNS_DIR=./runs
AI_CACHE_DIR=./ai-cache

# ---- Playwright ----
HEADLESS=true
STEALTH=0
DEBUG_CAPTURE=0
RECORD_HAR=0

# ---- Safety flag ----
# When DRY_RUN=1 the push pipeline logs payloads instead of hitting /addjob.
DRY_RUN=0

# ---- Downstream services ----
DASHBOARD_BASE=http://localhost:8086
# Shared secret for the scraper<->dashboard service-to-service calls.
# Set the matching value on the dashboard backend when GET /operations/clients lands.
DASHBOARD_SERVICE_TOKEN=change-me-shared-secret

RESUME_BASE=http://localhost:5000

# ---- OpenAI (Phase 4+) ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- JobRight (Phase 0+) ----
JOBRIGHT_BASE=https://jobright.ai
# Cooldown applied after 429/403 before accepting another run (ms).
JOBRIGHT_COOLDOWN_MS=900000
# Credentials for programmatic login. Leave blank to use manual headed login
# via POST /api/admin/first-login.
# IMPORTANT: quote the password if it contains `#` — Node's --env-file parser
# treats `#` as a comment start, so unquoted values get silently truncated.
# Example:  JOBRIGHT_PASSWORD="abc#def"
JOBRIGHT_EMAIL=
JOBRIGHT_PASSWORD=

# ---- MongoDB (optional — falls back to on-disk JSON when blank) ----
# Same URI the dashboard backend uses. When set, per-client filters + AI
# feedback persist to Mongo instead of runs/client-filters + runs/client-feedback.
# MONGO_URI=mongodb://localhost:27017
# MONGO_DB=flashfire_scraper

# ---- Discord webhook (optional — empty = no alerts) ----
# Where to post terminal run events (success / failure / cooldown / no-jobs).
# Treat as SECRET — anyone with this URL can post to the channel.
# DISCORD_WEBHOOK_URL=

# ---- Debug routes shared secret (optional) ----
# Gates /api/debug/* — when blank the routes are OPEN (fine on a firewalled
# box). When set, callers MUST send `X-Debug-Token: <value>` to access:
#   GET  /api/debug/snapshot          system overview (env redacted, cooldown,
#                                     mongo + browser status, last 5 runs)
#   GET  /api/debug/last-run          full debug bundle for the most recent run
#   GET  /api/debug/run/:id           same bundle for a specific run id
#   POST /api/debug/preview-filter    {clientEmail|intent} → JR filter payload
#                                     + list URL that WOULD be sent (no JR call)
#   POST /api/debug/dry-search        {clientEmail|intent, count?} → real JR
#                                     fetch only, raw + normalised jobs (no AI,
#                                     no push)
# DEBUG_TOKEN=
